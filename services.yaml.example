services:
  - name: Gitea
    github: go-gitea/gitea
    version_url: "http://192.168.1.10:3000/api/v1/version"
    version_key: "version"

  - name: Immich
    github: immich-app/immich
    version_url: "http://192.168.1.11:2283/api/server/version"
    version_template: "{major}.{minor}.{patch}"

  - name: Vaultwarden
    github: dani-garcia/vaultwarden
    # no version_url — manual input in UI

  - name: MyApp
    github: org/myapp
    version_url: "http://192.168.1.12:8080/metrics"
    version_metric: "cs_info"               # matches: cs_info{version="v1.2.3-build"} 0
    # version_label: "version"              # optional, defaults to "version"
    # version_regex: "v?(\\d+\\.\\d+\\.\\d+)"  # optional: trim build suffix → "1.2.3"

  - name: ProtectedApp
    github: org/protectedapp
    version_url: "http://192.168.1.13:9000/api/version"
    version_key: "version"
    auth_header: "Bearer mytoken123"        # full Authorization header value
    # basic_auth: "admin:secret"            # alternative: HTTP Basic Auth (user:pass)

  - name: CustomLatest
    version_url: "http://192.168.1.14:8080/api/version"
    version_key: "installed"
    latest_url: "http://192.168.1.14:8080/api/latest"  # fetch latest from REST API instead of GitHub
    latest_key: "version"                               # dot-notation key, e.g. "release.tag"
    # latest_regex: "v?(\\d+\\.\\d+\\.\\d+)"           # optional: strip prefix from result

  - name: Zigbee2MQTT
    github: Koenkk/zigbee2mqtt
    mqtt_broker: "192.168.1.10"               # MQTT broker hostname
    # mqtt_port: 1883                          # optional, defaults to 1883
    mqtt_topic: "zigbee2mqtt/bridge/info"     # publishes retained JSON with "version" key
    mqtt_username: "myuser"                   # optional
    mqtt_password: "mypassword"               # optional
    # version_key: "version"                  # optional, defaults to "version"
