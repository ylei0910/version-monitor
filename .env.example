# GitHub personal access token (OPTIONAL)
# With a 24h check interval and <25 services, the unauthenticated
# rate limit (60 req/hr) is never hit. Only set this if you have
# many services or a short check interval.
GITHUB_TOKEN=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram chat ID (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_chat_id_here

# How often to fetch GitHub releases AND send Telegram notifications, in minutes.
# Default: 1440 = once per day. Set to 0 to disable the scheduler entirely.
GITHUB_CHECK_INTERVAL_MINUTES=1440
